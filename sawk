#!/bin/sh
#
# sawk - slightly better awk
# BSD 3-Clause License - see LICENSE file

set -eu

VERSION="v0.0.1"
DEFAULT_OUTPUT="a.out"
SAWK_HOME="${HOME}/.sawk"

# Unique sentinel unlikely to appear in real awk source.
# Using a valid awk comment so gawk's pretty-printer preserves it.
EMPTY_PLACEHOLDER="#__SAWK_BLANK_LINE__"

_usage() {
	cat >&2 <<EOF
usage: sawk [-d] [-m] [-o output_file] [-v] [-h] file|-
       sawk install user/repo
       sawk remove  user/repo
       sawk list

Build tool for awk: resolves #include directives, lints, formats,
and wraps the result in an executable shell script that runs with
any POSIX awk.

Compilation options:
  -d          Enable debug mode
  -m          Non-fatal linting (warnings only)
  -o <file>   Output file (default: a.out)
  -v          Show version
  -h          Show this help

Include resolution:
  #include "./file.awk"       relative to the including file
  #include "user/repo/f.awk"  installed package in ~/.sawk/user/repo/
EOF
}

# _format: reads awk source from stdin, preserves blank lines through
# gawk's pretty-printer which would otherwise remove them.
# gawk is used here as a build-time tool only — the output targets
# POSIX awk and runs without gawk.
_format() {
	sed "s/^[	 ]*$/${EMPTY_PLACEHOLDER}/g" |
		gawk -o- -f- |
		sed "s/${EMPTY_PLACEHOLDER}//g"
}

# _lint FILE: lints the source file using gawk as a build-time tool.
# Rewrites #include to @include so gawk resolves them natively and
# reports errors with the correct file and line number.
# gawk is not required at runtime — the compiled output runs with
# any POSIX awk.
_lint() {
	sed 's|^#include "|@include "|g' "$1" | \
		gawk "--lint${fatal_flag}" -f - >/dev/null
}

# _wrap: reads awk source from stdin and wraps it in an executable
# shell script that invokes plain awk. Only strips the shebang line,
# preserving blank lines.
_wrap() {
	printf '%s\n' "#!/usr/bin/env sh" "exec awk '"
	sed '/^#!/d'
	printf '%s\n' "' -- \"\$@\""
}

# _link FILE [SEEN]: recursively inlines #include directives.
# Paths starting with ./ or ../ are resolved relative to the including
# file. All other paths are resolved from ~/.sawk/ as installed packages.
# SEEN is a colon-separated list of absolute paths already included,
# used to detect circular includes.
_link() {
	_lf="$1"
	_seen="${2:-}"

	# Resolve to absolute path for reliable cycle detection
	_abs="$(cd "$(dirname "$_lf")" && printf '%s/%s' "$(pwd)" "$(basename "$_lf")")"

	case ":${_seen}:" in
		*":${_abs}:"*)
			printf 'sawk: circular include: %s\n' "$_lf" >&2
			return 1
			;;
	esac
	_seen="${_seen}:${_abs}"

	while IFS= read -r _line || [ -n "$_line" ]; do
		case "$_line" in
			'#include "'*)
				_inc="${_line#*\"}"
				_inc="${_inc%\"*}"
				case "$_inc" in
					./*|../*)
						# Local path — resolve relative to including file
						_inc_path="$(dirname "$_abs")/${_inc}"
						;;
					*)
						# Package path — resolve from ~/.sawk/
						_inc_path="${SAWK_HOME}/${_inc}"
						;;
				esac
				if [ ! -f "$_inc_path" ]; then
					printf 'sawk: could not find include: %s\n' "$_inc" >&2
					return 1
				fi
				_link "$_inc_path" "$_seen"
				;;
			*)
				printf '%s\n' "$_line"
				;;
		esac
	done < "$_lf"
}

# _install user/repo: download a package from GitHub and install to
# ~/.sawk/user/repo/
_install() {
	[ "$#" -ne 1 ] && printf 'usage: sawk install user/repo\n' >&2 && exit 1

	_pkg="$1"
	_user="${_pkg%/*}"
	_repo="${_pkg#*/}"

	if [ "$_user" = "$_pkg" ] || [ -z "$_user" ] || [ -z "$_repo" ]; then
		printf 'sawk: invalid package name: %s (expected user/repo)\n' "$_pkg" >&2
		exit 1
	fi

	_dest="${SAWK_HOME}/${_user}/${_repo}"

	if [ -d "$_dest" ]; then
		printf 'sawk: %s is already installed\n' "$_pkg" >&2
		exit 1
	fi

	_url="https://github.com/${_pkg}/archive/refs/heads/main.tar.gz"
	_tmp="$(mktemp -d)"
	trap 'rm -rf "$_tmp"' EXIT

	printf 'sawk: downloading %s...\n' "$_pkg"
	if command -v curl >/dev/null 2>&1; then
		curl -sL -o "$_tmp/pkg.tar.gz" "$_url"
	elif command -v wget >/dev/null 2>&1; then
		wget -q -O "$_tmp/pkg.tar.gz" "$_url"
	else
		printf 'sawk: curl or wget is required to install packages\n' >&2
		exit 1
	fi

	mkdir -p "${SAWK_HOME}/${_user}"
	tar xzf "$_tmp/pkg.tar.gz" -C "$_tmp"
	mv "$_tmp/${_repo}-main" "$_dest"

	printf 'sawk: installed %s\n' "$_pkg"
}

# _remove user/repo: remove an installed package
_remove() {
	[ "$#" -ne 1 ] && printf 'usage: sawk remove user/repo\n' >&2 && exit 1

	_pkg="$1"
	_dest="${SAWK_HOME}/${_pkg}"

	if [ ! -d "$_dest" ]; then
		printf 'sawk: %s is not installed\n' "$_pkg" >&2
		exit 1
	fi

	rm -rf "$_dest"
	printf 'sawk: removed %s\n' "$_pkg"
}

# _list: list installed packages
_list() {
	[ ! -d "$SAWK_HOME" ] && exit 0
	find "$SAWK_HOME" -mindepth 2 -maxdepth 2 -type d | \
		sed "s|${SAWK_HOME}/||g" | \
		sort
}

# Subcommand dispatch
case "${1:-}" in
	install) shift; _install "$@"; exit 0 ;;
	remove)  shift; _remove  "$@"; exit 0 ;;
	list)    _list; exit 0 ;;
esac

# Option parsing
fatal_flag="=fatal"
output_file="${DEFAULT_OUTPUT}"

while getopts "dmo:vh" opt; do
	case "$opt" in
		d) set -x ;;
		m) fatal_flag="" ;;
		o) output_file="$OPTARG" ;;
		v) printf 'sawk %s\n' "$VERSION"; exit 0 ;;
		h) _usage; exit 0 ;;
		*) _usage; exit 1 ;;
	esac
done
shift $((OPTIND - 1))

if [ "$#" -ne 1 ]; then
	_usage
	exit 1
fi

# Handle stdin: copy to a temp file so _link and _lint can read it
input="$1"
tmp_stdin=""
if [ "$input" = "-" ]; then
	tmp_stdin="$(mktemp)"
	trap 'rm -f "$tmp_stdin"' EXIT
	cat > "$tmp_stdin"
	input="$tmp_stdin"
fi

# Write linked output to a temp file so we don't run _link twice
tmp="$(mktemp)"
if [ -n "$tmp_stdin" ]; then
	trap 'rm -f "$tmp_stdin" "$tmp"' EXIT
else
	trap 'rm -f "$tmp"' EXIT
fi

# Lint the original source — gawk resolves @include natively so errors
# reference the correct file and line number
_lint "$input"

# Link everything into a single POSIX awk file
_link "$input" > "$tmp"

_format < "$tmp" | _wrap > "$output_file"
chmod +x "$output_file"
printf '%s\n' "$output_file"
